---
import PageLayout from '../../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  const experimentsDir = path.join(process.cwd(), 'public/architecture/experiments');
  let experimentSlugs: string[] = [];
  if (fs.existsSync(experimentsDir)) {
    experimentSlugs = fs.readdirSync(experimentsDir).filter((file: string) => {
      return fs.statSync(path.join(experimentsDir, file)).isDirectory();
    });
  }

  // Also include slugs from content collection if they don't have folders yet (for "coming soon" state)
  const experiments = await getCollection('experiments');
  const allSlugs = new Set([...experimentSlugs, ...experiments.map(e => e.id)]);

  return Array.from(allSlugs).map(slug => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

// Discover experiment details
const experiments = await getCollection('experiments');
const experiment = experiments.find(e => e.id === slug);
const title = experiment ? experiment.data.title : slug.split('-').map((word: string) => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');

const frontmatter = {
  title: `${title} Architecture`,
  description: `Architectural visualisations and documentation for the ${title} experiment.`,
};

// Title generation helper
const generateTitle = (filename: string) => {
  return filename
    .replace('.drawio.svg', '')
    .replace(/-/g, ' ')
    .split(' ')
    .map((word: string) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
};

// Scan for diagrams
const baseDir = path.join(process.cwd(), `public/architecture/experiments/${slug}`);
let mainDiagrams: any[] = [];
let sequenceDiagrams: any[] = [];

if (fs.existsSync(baseDir)) {
  // Main diagrams
  mainDiagrams = fs.readdirSync(baseDir)
    .filter((file: string) => file.endsWith('.drawio.svg'))
    .map((file: string) => ({
      filename: file,
      title: generateTitle(file),
      path: `/architecture/experiments/${slug}/${file}`
    }));

  // Sequence diagrams
  const sequenceDir = path.join(baseDir, 'sequence');
  if (fs.existsSync(sequenceDir) && fs.statSync(sequenceDir).isDirectory()) {
    sequenceDiagrams = fs.readdirSync(sequenceDir)
      .filter((file: string) => file.endsWith('.drawio.svg'))
      .map((file: string) => ({
        filename: file,
        title: generateTitle(file),
        path: `/architecture/experiments/${slug}/sequence/${file}`
      }));
  }
}

// Linkage discovery
const experimentLink = experiment ? `/experiments/${slug}` : null;

// Pattern linkage (look for patterns referencing this experiment)
const allPatterns = await getCollection('patterns');
const relatedPatterns = allPatterns.filter(p => 
  p.data.relatedExperiments?.includes(slug) || 
  p.id === slug ||
  p.data.title.toLowerCase().includes(title.toLowerCase())
);

// Learning linkage (look for learnings referencing this experiment)
const allLearnings = await getCollection('learnings');
const relatedLearnings = allLearnings.filter(l => 
  l.data.title.toLowerCase().includes(title.toLowerCase()) ||
  l.body.toLowerCase().includes(slug.toLowerCase())
).slice(0, 5); // Limit to 5
---

<PageLayout frontmatter={frontmatter}>
  {experimentLink && (
    <div class="mb-12">
        <a href={experimentLink} class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-accent-blue/10 border border-accent-blue/20 text-accent-blue font-bold hover:bg-accent-blue/20 transition-all group">
            <span>View experiment</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
    </div>
  )}

  <div class="space-y-24">
    {mainDiagrams.length > 0 || sequenceDiagrams.length > 0 ? (
      <>
        {mainDiagrams.length > 0 && (
          <div class="space-y-16">
            {mainDiagrams.map(diagram => (
              <section>
                <div class="flex items-center gap-4 mb-8">
                  <h3 class="text-2xl font-display font-extrabold text-white">{diagram.title}</h3>
                  <div class="h-px flex-1 bg-white/10"></div>
                </div>
                <div class="glass p-8 md:p-12 rounded-[2rem] overflow-hidden border border-white/10 shadow-2xl bg-white/5">
                  <img src={diagram.path} alt={diagram.title} class="w-full h-auto" loading="lazy" data-zoomable />
                </div>
              </section>
            ))}
          </div>
        )}

        {sequenceDiagrams.length > 0 && (
          <section class="pt-12">
            <h2 class="text-3xl font-display font-extrabold text-white mb-12">Runtime Flows</h2>
            <div class="space-y-16">
              {sequenceDiagrams.map(diagram => (
                <section>
                  <div class="flex items-center gap-4 mb-8">
                    <h3 class="text-xl font-display font-bold text-white/70">{diagram.title}</h3>
                    <div class="h-px flex-1 bg-white/5"></div>
                  </div>
                  <div class="glass p-8 md:p-12 rounded-[2rem] overflow-hidden border border-white/10 shadow-2xl bg-white/5">
                    <img src={diagram.path} alt={diagram.title} class="w-full h-auto" loading="lazy" data-zoomable />
                  </div>
                </section>
              ))}
            </div>
          </section>
        )}
      </>
    ) : (
      <div class="glass p-24 rounded-[3rem] text-center border border-white/10">
        <p class="text-2xl text-white/40 italic">Architecture diagrams coming soon.</p>
      </div>
    )}
  </div>

  {(relatedPatterns.length > 0 || relatedLearnings.length > 0) && (
    <div class="mt-32 pt-16 border-t border-white/10 grid md:grid-cols-2 gap-12">
      {relatedPatterns.length > 0 && (
        <section>
          <h2 class="text-xl uppercase tracking-widest text-white/40 mb-8">Related Patterns</h2>
          <ul class="space-y-4">
            {relatedPatterns.map(pattern => (
              <li>
                <a href={`/architecture/patterns/${pattern.id}`} class="text-lg font-medium text-white/80 hover:text-accent-sunset transition-colors flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-accent-sunset"></span>
                  {pattern.data.title}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {relatedLearnings.length > 0 && (
        <section>
          <h2 class="text-xl uppercase tracking-widest text-white/40 mb-8">Related Learnings</h2>
          <ul class="space-y-4">
            {relatedLearnings.map(learning => (
              <li>
                <a href={`/learnings/${learning.id}`} class="text-lg font-medium text-white/80 hover:text-accent-blue transition-colors flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-accent-blue"></span>
                  {learning.data.title}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </div>
  )}

  <div class="mt-24 pt-12 border-t border-white/5">
    <a href="/architecture" class="inline-flex items-center gap-2 text-white/50 hover:text-white transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
      Back to Architecture
    </a>
  </div>
</PageLayout>

<script>
  import mediumZoom from 'medium-zoom';

  const setupZoom = () => {
    mediumZoom('[data-zoomable]', {
      margin: 24,
      background: 'rgba(15, 23, 42, 0.95)',
    });
  };

  // Initial load
  setupZoom();
  // Navigation load (Astro View Transitions)
  document.addEventListener('astro:page-load', setupZoom);
</script>

<style is:global>
  .medium-zoom-overlay {
    backdrop-filter: blur(10px);
    z-index: 50;
  }
  .medium-zoom-image--opened {
    z-index: 51;
    border-radius: 0.5rem;
  }
</style>
