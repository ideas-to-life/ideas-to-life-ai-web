---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';

const frontmatter = {
  title: 'Architecture',
  description: 'Visualising the architecture of Ideas-to-Life system and experiments.',
};

// Discover experiment architecture folders
const experimentsDir = path.join(process.cwd(), 'public/architecture/experiments');
let experimentSlugs = [];
if (fs.existsSync(experimentsDir)) {
  experimentSlugs = fs.readdirSync(experimentsDir).filter(file => {
    return fs.statSync(path.join(experimentsDir, file)).isDirectory();
  });
}

const experiments = await getCollection('experiments');
const experimentLinks = experimentSlugs.map(slug => {
  const experiment = experiments.find(e => e.slug === slug);
  return {
    slug,
    title: experiment ? experiment.data.title : slug.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' '),
  };
});
---

<PageLayout frontmatter={frontmatter}>
  <section class="mb-20">
    <h2 class="text-3xl font-display font-extrabold text-white mb-8">Platform Architecture</h2>
    <div class="grid gap-6">
      <a href="/architecture/platform" class="glass p-8 rounded-3xl hover:bg-white/5 transition-all group">
        <div class="flex justify-between items-center">
          <div>
            <h3 class="text-2xl font-bold text-white group-hover:text-accent-blue transition-colors">Core System</h3>
            <p class="text-white/60 mt-2">Explore the high-level architecture of the Ideas-to-Life platform.</p>
          </div>
          <div class="text-accent-blue opacity-0 group-hover:opacity-100 transition-opacity">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </div>
        </div>
      </a>
    </div>
  </section>

  <section>
    <h2 class="text-3xl font-display font-extrabold text-white mb-8">Experiment Architectures</h2>
    {experimentLinks.length > 0 ? (
      <div class="grid gap-6">
        {experimentLinks.map(exp => (
          <a href={`/architecture/experiments/${exp.slug}`} class="glass p-8 rounded-3xl hover:bg-white/5 transition-all group">
            <div class="flex justify-between items-center">
              <div>
                <h3 class="text-2xl font-bold text-white group-hover:text-accent-blue transition-colors">{exp.title}</h3>
                <p class="text-white/60 mt-2">View architectural diagrams for the {exp.title} experiment.</p>
              </div>
              <div class="text-accent-blue opacity-0 group-hover:opacity-100 transition-opacity">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="glass p-12 rounded-3xl text-center">
        <p class="text-white/40 italic">Architecture diagrams coming soon.</p>
      </div>
    )}
  </section>
</PageLayout>
