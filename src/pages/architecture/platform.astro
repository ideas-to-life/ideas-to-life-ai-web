---
import PageLayout from '../../layouts/PageLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const frontmatter = {
  title: 'Platform Architecture',
  description: 'The core system architecture of the Ideas-to-Life platform.',
};

// Title generation helper
const generateTitle = (filename: string) => {
  return filename
    .replace('.drawio.svg', '')
    .replace(/-/g, ' ')
    .split(' ')
    .map((word: string) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
};

// Discover platform diagrams
const platformDir = path.join(process.cwd(), 'public/architecture/platform');
let diagrams: any[] = [];
if (fs.existsSync(platformDir)) {
  diagrams = fs.readdirSync(platformDir)
    .filter((file: string) => file.endsWith('.drawio.svg'))
    .map((file: string) => ({
      filename: file,
      title: generateTitle(file),
      path: `/architecture/platform/${file}`
    }));
}
---

<PageLayout frontmatter={frontmatter}>
  {diagrams.length > 0 ? (
    <div class="space-y-24">
      {diagrams.map(diagram => (
        <section>
          <div class="flex items-center gap-4 mb-8">
            <h2 class="text-3xl font-display font-extrabold text-white">{diagram.title}</h2>
            <div class="h-px flex-1 bg-white/10"></div>
          </div>
          
          <div class="glass p-8 md:p-12 rounded-[2rem] overflow-hidden border border-white/10 shadow-2xl bg-white/5">
            <img 
              src={diagram.path} 
              alt={diagram.title} 
              class="w-full h-auto max-w-full rounded-xl"
              loading="lazy"
            />
          </div>
        </section>
      ))}
    </div>
  ) : (
    <div class="glass p-24 rounded-[3rem] text-center border border-white/10">
      <p class="text-2xl text-white/40 italic">Architecture diagrams coming soon.</p>
    </div>
  )}

  <div class="mt-24 pt-12 border-t border-white/5">
    <a href="/architecture" class="inline-flex items-center gap-2 text-white/50 hover:text-white transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
      Back to Architecture
    </a>
  </div>
</PageLayout>
